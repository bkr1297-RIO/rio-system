---
title: Governed Email Deployment — System Architecture
---
graph TB
    subgraph Customer["Customer Environment"]
        AI["AI Agent<br/>(OpenAI / Anthropic / Custom)"]
    end

    subgraph Docker["Docker Host (Single Server or K8s)"]
        subgraph Gateway["RIO Gateway (Express/Node.js)"]
            direction TB
            INTAKE["Intent Intake<br/>POST /api/v1/intents"]
            POLICY["Policy Engine<br/>Risk: LOW | MED | HIGH | CRITICAL"]
            AUTHGATE["Authorization Gate<br/>Ed25519 Verify + Nonce Check"]
            FCGATE["Fail-Closed Gate<br/>Default: BLOCK"]
            RECEIPT["Receipt Generator<br/>SHA-256 + Ed25519"]
        end

        subgraph ONE["ONE Command Center (React PWA)"]
            DASH["Approval Dashboard"]
            KILL["Kill Switch"]
            AUDIT["Audit Viewer"]
        end

        subgraph Connector["Email Connector"]
            GMAIL["Gmail API<br/>(OAuth2)"]
            SMTP["SMTP Relay<br/>(Exchange/Outlook)"]
        end

        subgraph DB["Database (MySQL)"]
            LEDGER["Hash-Chained Ledger<br/>(Append-Only)"]
            INTENTS["Intents Table"]
            RECEIPTS["Receipts Table"]
        end
    end

    subgraph External["External"]
        RECIPIENT["Email Recipient"]
        TGBOT["Telegram Bot<br/>(Approve/Deny)"]
    end

    HUMAN["Human Governor"]

    AI -->|"1. Submit Intent"| INTAKE
    INTAKE -->|"2. Assess Risk"| POLICY
    POLICY -->|"3. Queue for Approval"| DASH
    POLICY -->|"3. Queue for Approval"| TGBOT
    HUMAN -->|"4. Approve (Ed25519)"| DASH
    HUMAN -->|"4. Approve (Ed25519)"| TGBOT
    DASH -->|"5. Signed Decision"| AUTHGATE
    TGBOT -->|"5. Signed Decision"| AUTHGATE
    AUTHGATE -->|"6. Token Issued"| FCGATE
    FCGATE -->|"7. Execute"| GMAIL
    FCGATE -->|"7. Execute"| SMTP
    GMAIL -->|"8. Send"| RECIPIENT
    SMTP -->|"8. Send"| RECIPIENT
    GMAIL -->|"9. Result"| RECEIPT
    SMTP -->|"9. Result"| RECEIPT
    RECEIPT -->|"10. Record"| LEDGER
    INTAKE --> INTENTS
    RECEIPT --> RECEIPTS

    AUTHGATE -.->|"No Token → 403"| AI

    classDef customer fill:#1a1a2e,stroke:#e2b340,color:#fff
    classDef gateway fill:#16213e,stroke:#e2b340,color:#fff
    classDef one fill:#0f3460,stroke:#4a9eff,color:#fff
    classDef connector fill:#1a1a2e,stroke:#22c55e,color:#fff
    classDef db fill:#1a1a2e,stroke:#a855f7,color:#fff
    classDef external fill:#1a1a2e,stroke:#94a3b8,color:#fff
    classDef human fill:#0f3460,stroke:#e2b340,color:#fff
    classDef deny fill:#dc2626,stroke:#dc2626,color:#fff

    class AI customer
    class INTAKE,POLICY,AUTHGATE,FCGATE,RECEIPT gateway
    class DASH,KILL,AUDIT one
    class GMAIL,SMTP connector
    class LEDGER,INTENTS,RECEIPTS db
    class RECIPIENT,TGBOT external
    class HUMAN human
