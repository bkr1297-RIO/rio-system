# =============================================================================
# RIO Governance Gateway — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Start the system:
#   docker compose up -d
#
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL Database
# ---------------------------------------------------------------------------
# Password for the PostgreSQL database user 'rio'.
# Used by both the postgres container and the gateway's DATABASE_URL.
# CHANGE THIS IN PRODUCTION.
PG_PASSWORD=rio_gateway_2026

# External port to expose PostgreSQL on the host (default: 5432).
# Change if you have another PostgreSQL instance running.
# PG_EXTERNAL_PORT=5432

# ---------------------------------------------------------------------------
# Gateway Server
# ---------------------------------------------------------------------------
# Port the gateway listens on (default: 4400).
# RIO_GATEWAY_PORT=4400

# Ed25519 enforcement: "optional" (accepts unsigned) or "required" (rejects unsigned)
ED25519_MODE=required

# ---------------------------------------------------------------------------
# Authentication  [REQUIRED — change before first run]
# ---------------------------------------------------------------------------
# Secret key for signing JWT tokens. Generate with:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Passphrase for the MVP login endpoint (fallback when OAuth is not configured).
RIO_LOGIN_PASSPHRASE=rio-governed-2026

# ---------------------------------------------------------------------------
# Google OAuth  [REQUIRED for multi-user login]
# ---------------------------------------------------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: http://localhost:4400/auth/google/callback
#
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# JWT token expiry in hours (default: 24).
# TOKEN_EXPIRY_HOURS=24

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
# Maximum requests per window for the public API (default: 100).
# RATE_LIMIT_GLOBAL=100

# Rate limit window in seconds (default: 60).
# REQUEST_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Hours to retain nonces for replay prevention (default: 24).
# NONCE_RETENTION_HOURS=24

# Seconds before an execution token expires (default: 300 = 5 minutes).
# EXECUTION_TOKEN_EXPIRY_SECONDS=300

# ---------------------------------------------------------------------------
# External API Keys (for connectors)
# All API calls go through the gateway — keys are never exposed to agents.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GITHUB_TOKEN=ghp_...

# ---------------------------------------------------------------------------
# Monitoring (Optional)
# ---------------------------------------------------------------------------
# Webhook URL for system alerts (Slack, Discord, etc.).
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email address for critical alerts.
# ALERT_EMAIL=ops@yourcompany.com
