# RIO Governance Gateway — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------
RIO_GATEWAY_PORT=4400
NODE_ENV=production

# -----------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------
# JWT secret for session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# Login passphrase (MVP — replace with OAuth in production)
RIO_LOGIN_PASSPHRASE=CHANGE_ME_SET_A_STRONG_PASSPHRASE

# Ed25519 enforcement: "optional" (accepts unsigned) or "required" (rejects unsigned)
ED25519_MODE=optional

# -----------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------
POSTGRES_PASSWORD=CHANGE_ME_SET_A_STRONG_PASSWORD
PGHOST=postgres
PGPORT=5432
PGDATABASE=rio_ledger
PGUSER=rio
PGPASSWORD=CHANGE_ME_SET_A_STRONG_PASSWORD

# -----------------------------------------------------------------------
# External API Keys (for connectors)
# All API calls go through the gateway — keys are never exposed to agents.
# -----------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GITHUB_TOKEN=ghp_...
