{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RIO Compliance Report",
  "description": "Schema for compliance reports generated by the RIO compliance runner.",
  "type": "object",
  "required": ["_meta", "summary", "results"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["type", "version", "generated_at", "runner"],
      "properties": {
        "type": { "type": "string", "const": "compliance_report" },
        "version": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "runner": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "overall"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "overall": { "type": "string", "enum": ["PASS", "FAIL"] }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario", "claim", "passFail", "evidence", "timestamp"],
        "properties": {
          "scenario": { "type": "string", "pattern": "^S[0-9]+$" },
          "claim": { "type": "string" },
          "passFail": { "type": "string", "enum": ["PASS", "FAIL", "PENDING"] },
          "evidence": { "type": "object" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
