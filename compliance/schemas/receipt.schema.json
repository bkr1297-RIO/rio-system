{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pgtc.rio.dev/schemas/receipt.schema.json",
  "title": "PGTC Receipt",
  "description": "Post-execution proof recording the outcome, intent hash, and execution result.",
  "type": "object",
  "required": ["receipt_id", "intent_hash", "status", "timestamp"],
  "properties": {
    "receipt_id": {
      "type": "string",
      "description": "Unique identifier for this receipt"
    },
    "intent_hash": {
      "type": "string",
      "description": "Hash of the canonical intent packet that was executed"
    },
    "status": {
      "type": "string",
      "enum": ["ALLOWED", "BLOCKED"],
      "description": "Execution outcome"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of receipt creation"
    },
    "execution_result": {
      "type": "object",
      "description": "The result returned by the adapter"
    },
    "x_extensions": {
      "type": "object",
      "description": "Implementation-specific extension fields"
    }
  },
  "additionalProperties": false
}
