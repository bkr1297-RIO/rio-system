{
  "one_governance_policy": {
    "policy_id": "ONE-GOV-DEPLOY-001",
    "policy_name": "Build Authority / Deploy Boundary",
    "version": "1.0",
    "status": "active",
    "purpose": "Allow agents to fully prepare systems for release while preserving explicit human authority over live externalization and irreversible change.",
    "scope": {
      "systems": ["ONE", "RIO", "Bondi", "PCP", "connected_agent_runtimes"],
      "agents": ["MANUS", "Claude", "GPT", "Gemini", "Grok", "internal_subagents"],
      "environments": ["local", "dev", "staging", "production"]
    },
    "governance_model": {
      "human_final_authority": true,
      "build_authority": "granted",
      "deploy_authority": "withheld_pending_explicit_human_approval",
      "decision_default": "fail_closed"
    },
    "agent_permissions": {
      "allowed_by_default": [
        "design",
        "draft",
        "write_code",
        "refactor",
        "document",
        "connect_services",
        "configure_dev",
        "configure_staging",
        "prepare_infrastructure",
        "prepare_release",
        "run_non_destructive_tests",
        "simulate_actions",
        "ask_questions",
        "stage_changes",
        "prepare_prs",
        "prepare_migrations",
        "prepare_connectors"
      ],
      "restricted_until_approved": [
        "deploy_staging",
        "deploy_production",
        "publish_live_site",
        "enable_live_connector",
        "send_external_communications",
        "write_production_data",
        "modify_live_auth",
        "modify_live_billing",
        "modify_live_dns",
        "modify_live_security_controls",
        "persist_external_canonical_records",
        "execute_irreversible_external_action"
      ]
    },
    "approval_requirements": {
      "required": true,
      "must_be_explicit": true,
      "must_be_informed": true,
      "must_be_time_bound": true,
      "must_be_in_scope": true,
      "required_fields": [
        "change_summary",
        "target_environment",
        "expected_effects",
        "risks",
        "rollback_plan",
        "approval_expires_at"
      ]
    },
    "runtime_rules": [
      "Prepare to the edge of deployment by default",
      "Pause before restricted actions",
      "If scope is ambiguous, do not proceed",
      "If approval is expired, do not proceed",
      "If approval does not match environment, do not proceed",
      "If action has external effect and classification is uncertain, classify as restricted"
    ],
    "approval_request_shape": {
      "change_summary": "string",
      "target_environment": "local|dev|staging|production",
      "expected_effects": "string",
      "risks": "string",
      "rollback_plan": "string",
      "approval_expires_at": "ISO-8601 datetime",
      "requested_by": "agent_id",
      "approved_by": "human_id|null"
    }
  }
}
