{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pgtc.rio.dev/schemas/intent-packet.schema.json",
  "title": "PGTC Intent Packet",
  "description": "Canonical structured representation of intent. If a field is not in the packet, it MUST NOT be executed.",
  "type": "object",
  "required": ["packet_id", "packet_version", "action", "parameters", "timestamp"],
  "properties": {
    "packet_id": {
      "type": "string",
      "description": "Unique identifier for this packet"
    },
    "packet_version": {
      "type": "string",
      "description": "PGTC specification version (e.g., 0.1)"
    },
    "action": {
      "type": "string",
      "description": "The action to perform"
    },
    "parameters": {
      "type": "object",
      "description": "Action parameters — the exact content to execute"
    },
    "trajectory_id": {
      "type": ["string", "null"],
      "description": "Identifier for the trajectory this packet belongs to, if any"
    },
    "step_id": {
      "type": ["string", "null"],
      "description": "Step identifier within the trajectory"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of packet creation"
    },
    "hash_alg": {
      "type": "string",
      "description": "Hash algorithm used for intent_hash (default: SHA-256)",
      "default": "SHA-256"
    },
    "canon_alg": {
      "type": "string",
      "description": "Canonicalization algorithm (default: JCS — JSON Canonicalization Scheme)",
      "default": "JCS"
    },
    "x_extensions": {
      "type": "object",
      "description": "Implementation-specific extension fields"
    }
  },
  "additionalProperties": false
}
