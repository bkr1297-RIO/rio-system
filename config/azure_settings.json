{
  "_comment": "RIO Azure Integration Settings — Fill in your values from Azure Portal",
  "_instructions": "See docs/azure-integration-guide.md for step-by-step setup",

  "tenant": {
    "tenant_id": "YOUR_AZURE_TENANT_ID",
    "tenant_name": "YOUR_TENANT_NAME.onmicrosoft.com"
  },

  "app_registration": {
    "client_id": "YOUR_APP_CLIENT_ID",
    "client_secret_ref": "STORED_IN_AZURE_KEY_VAULT",
    "redirect_uri": "https://localhost/auth/callback",
    "authority": "https://login.microsoftonline.com/YOUR_AZURE_TENANT_ID"
  },

  "graph_api": {
    "scopes": [
      "Mail.Read",
      "Mail.ReadBasic",
      "User.Read"
    ],
    "base_url": "https://graph.microsoft.com/v1.0",
    "mailbox": "YOUR_EMAIL@outlook.com"
  },

  "webhook": {
    "azure_logic_app_url": "YOUR_LOGIC_APP_HTTP_TRIGGER_URL",
    "notification_channel": "webhook",
    "retry_count": 2,
    "timeout_seconds": 10
  },

  "storage": {
    "storage_account": "YOUR_STORAGE_ACCOUNT_NAME",
    "container": "rio-packets",
    "connection_string_ref": "STORED_IN_AZURE_KEY_VAULT"
  },

  "governance": {
    "read_only": true,
    "allowed_actions": ["observe", "compare", "summarize", "notify"],
    "blocked_actions": ["send", "delete", "modify", "forward"],
    "fail_closed": true
  }
}
